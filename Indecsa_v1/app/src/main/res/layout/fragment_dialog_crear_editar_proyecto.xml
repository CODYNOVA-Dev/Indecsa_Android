<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="20dp">

        <TextView
            android:id="@+id/txtTituloDialog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NUEVO PROYECTO"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="20dp"
            android:textColor="#2196F3" />

        <!-- Nombre del Proyecto -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre del Proyecto:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:textColor="#333333" />

        <EditText
            android:id="@+id/etNombreProyecto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ej: Torre Reforma"
            android:padding="16dp"
            android:layout_marginBottom="20dp"
            android:textSize="16sp" />

        <!-- ⭐⭐ ELIMINADO: Descripción ⭐⭐ -->
        <!-- <TextView ... Descripción ... />
           <EditText ... etDescripcion ... /> -->

        <!-- Contratista -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Contratista:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:textColor="#333333" />

        <EditText
            android:id="@+id/etContratista"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ej: Constructora Mexicana S.A."
            android:padding="16dp"
            android:layout_marginBottom="20dp"
            android:textSize="16sp" />

        <!-- Especialidad -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Especialidad:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:textColor="#333333" />

        <Spinner
            android:id="@+id/spinnerEspecialidad"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:padding="12dp"
            android:layout_marginBottom="20dp"
            android:textSize="16sp" />

        <!-- Estado -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Estado:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:textColor="#333333" />

        <Spinner
            android:id="@+id/spinnerEstado"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:padding="12dp"
            android:layout_marginBottom="20dp"
            android:textSize="16sp" />

        <!-- Dirección -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dirección:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:textColor="#333333" />

        <EditText
            android:id="@+id/etDireccion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ej: Paseo de la Reforma 250, CDMX"
            android:padding="16dp"
            android:layout_marginBottom="30dp"
            android:textSize="16sp" />

        <!-- Botones -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btnCancelar"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:text="CANCELAR"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:layout_marginRight="8dp"
                />

            <Button
                android:id="@+id/btnGuardar"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:text="GUARDAR"
                android:textAllCaps="false"
                android:textSize="16sp"
                 />

        </LinearLayout>

    </LinearLayout>

</ScrollView>