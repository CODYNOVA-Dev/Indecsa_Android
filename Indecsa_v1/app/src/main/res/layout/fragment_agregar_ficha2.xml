<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EFEFEF">

    <LinearLayout
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AGREGAR FICHA"
            android:gravity="center"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textColor="#2D2858"
            android:layout_marginBottom="20dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="18dp"
            android:orientation="vertical"
            android:background="@drawable/shape_card_round"
            android:elevation="6dp">

            <!-- SELECCIÓN DE CONTRATISTA -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Seleccionar Contratista"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#2D2858"
                android:layout_marginBottom="10dp"/>

            <Spinner
                android:id="@+id/spinnerContratista"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:background="@drawable/shape_input"
                android:layout_marginBottom="20dp"/>

            <!-- SELECCIÓN DE PROYECTO -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Seleccionar Proyecto"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#2D2858"
                android:layout_marginBottom="10dp"/>

            <Spinner
                android:id="@+id/spinnerProyecto"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:background="@drawable/shape_input"
                android:layout_marginBottom="20dp"/>

            <!-- ESTADO DE LA FICHA -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Estado de la Ficha"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#2D2858"
                android:layout_marginBottom="10dp"/>

            <Spinner
                android:id="@+id/spinnerEstadoFicha"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:background="@drawable/shape_input"
                android:layout_marginBottom="20dp"/>

            <!-- ESPECIALIDAD DE LA FICHA -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Especialidad de la Ficha"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#2D2858"
                android:layout_marginBottom="10dp"/>

            <Spinner
                android:id="@+id/spinnerEspecialidadFicha"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:background="@drawable/shape_input"
                android:layout_marginBottom="20dp"/>

            <!-- SELECCIÓN DE TRABAJADORES -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Seleccionar Trabajadores"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#2D2858"
                android:layout_marginBottom="10dp"/>

            <ListView
                android:id="@+id/listViewTrabajadores"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:background="@drawable/shape_input"
                android:choiceMode="multipleChoice"
                android:divider="#E0E0E0"
                android:dividerHeight="1dp"/>

        </LinearLayout>

        <Button
            android:id="@+id/btnGuardarFicha"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="GUARDAR FICHA"
            android:textColor="#FFF"
            android:background="@drawable/shape_button"
            android:layout_marginTop="20dp"/>
    </LinearLayout>
</ScrollView>