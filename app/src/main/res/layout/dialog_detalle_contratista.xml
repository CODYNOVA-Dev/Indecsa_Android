<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- ══════════════ PANEL DETALLE ══════════════ -->
        <LinearLayout
            android:id="@+id/panelDetalle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <!-- Cabecera -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/dialogTvAvatar"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/pill_blue"
                    android:gravity="center"
                    android:text="C"
                    android:textColor="@color/text_white"
                    android:textSize="24sp"
                    android:fontFamily="sans-serif-black"
                    android:textStyle="bold"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <TextView
                        android:id="@+id/dialogTvNombre"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nombre Contratista"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-black"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/dialogTvEstado"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/item_disp_verde"
                        android:text="● Activo"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/text_hint"
                android:alpha="0.3"
                android:layout_marginBottom="16dp"/>

            <!-- RFC -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="RFC" android:textColor="@color/text_hint" android:textSize="12sp"/>
            <TextView
                android:id="@+id/dialogTvRfc"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="—" android:textColor="@color/text_primary"
                android:textSize="15sp" android:layout_marginBottom="12dp"/>

            <!-- Correo -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Correo" android:textColor="@color/text_hint" android:textSize="12sp"/>
            <TextView
                android:id="@+id/dialogTvCorreo"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="—" android:textColor="@color/text_primary"
                android:textSize="15sp" android:layout_marginBottom="12dp"/>

            <!-- Teléfono -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Teléfono" android:textColor="@color/text_hint" android:textSize="12sp"/>
            <TextView
                android:id="@+id/dialogTvTelefono"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="—" android:textColor="@color/text_primary"
                android:textSize="15sp" android:layout_marginBottom="12dp"/>

            <!-- Experiencia -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Experiencia" android:textColor="@color/text_hint" android:textSize="12sp"/>
            <TextView
                android:id="@+id/dialogTvExperiencia"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="—" android:textColor="@color/text_primary"
                android:textSize="15sp" android:layout_marginBottom="12dp"/>

            <!-- Calificación -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Calificación" android:textColor="@color/text_hint" android:textSize="12sp"/>
            <RatingBar
                android:id="@+id/dialogRatingBar"
                style="?android:attr/ratingBarStyleSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:numStars="5"
                android:stepSize="0.5"
                android:isIndicator="true"
                android:progressTint="#D4AF37"
                android:secondaryProgressTint="#D4AF37"
                android:layout_marginBottom="12dp"/>

            <!-- Descripción -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Descripción" android:textColor="@color/text_hint" android:textSize="12sp"/>
            <TextView
                android:id="@+id/dialogTvDescripcion"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="—" android:textColor="@color/text_primary"
                android:textSize="15sp" android:layout_marginBottom="24dp"/>

            <!-- Botones -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnEliminar"
                    android:layout_width="wrap_content" android:layout_height="40dp"
                    android:background="@drawable/boton_rojo"
                    android:text="Eliminar" android:textAllCaps="false"
                    android:textColor="@android:color/white" android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:paddingStart="20dp" android:paddingEnd="20dp"
                    android:layout_marginEnd="10dp"/>

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnEditar"
                    android:layout_width="wrap_content" android:layout_height="40dp"
                    android:background="@drawable/boton_principal_v2"
                    android:text="Editar" android:textAllCaps="false"
                    android:textColor="@android:color/white" android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:paddingStart="20dp" android:paddingEnd="20dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ══════════════ PANEL EDITAR ══════════════ -->
        <LinearLayout
            android:id="@+id/panelEditar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Editar contratista"
                android:textColor="@color/text_primary" android:textSize="18sp"
                android:fontFamily="sans-serif-black" android:textStyle="bold"
                android:layout_marginBottom="20dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Nombre" android:textColor="@color/text_hint" android:textSize="12sp"/>
            <EditText android:id="@+id/editNombre"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/entrada_texto" android:padding="10dp"
                android:textSize="15sp" android:textColor="@color/text_primary"
                android:inputType="textPersonName" android:layout_marginBottom="12dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="RFC" android:textColor="@color/text_hint" android:textSize="12sp"/>
            <EditText android:id="@+id/editRfc"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/entrada_texto" android:padding="10dp"
                android:textSize="15sp" android:textColor="@color/text_primary"
                android:inputType="textCapCharacters" android:layout_marginBottom="12dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Correo" android:textColor="@color/text_hint" android:textSize="12sp"/>
            <EditText android:id="@+id/editCorreo"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/entrada_texto" android:padding="10dp"
                android:textSize="15sp" android:textColor="@color/text_primary"
                android:inputType="textEmailAddress" android:layout_marginBottom="12dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Teléfono" android:textColor="@color/text_hint" android:textSize="12sp"/>
            <EditText android:id="@+id/editTelefono"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/entrada_texto" android:padding="10dp"
                android:textSize="15sp" android:textColor="@color/text_primary"
                android:inputType="phone" android:layout_marginBottom="12dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Ubicación" android:textColor="@color/text_hint" android:textSize="12sp"/>
            <EditText android:id="@+id/editUbicacion"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/entrada_texto" android:padding="10dp"
                android:textSize="15sp" android:textColor="@color/text_primary"
                android:inputType="text" android:layout_marginBottom="12dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Experiencia" android:textColor="@color/text_hint" android:textSize="12sp"/>
            <EditText android:id="@+id/editExperiencia"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/entrada_texto" android:padding="10dp"
                android:textSize="15sp" android:textColor="@color/text_primary"
                android:inputType="textMultiLine" android:minLines="2"
                android:layout_marginBottom="12dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Descripción" android:textColor="@color/text_hint" android:textSize="12sp"/>
            <EditText android:id="@+id/editDescripcion"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/entrada_texto" android:padding="10dp"
                android:textSize="15sp" android:textColor="@color/text_primary"
                android:inputType="textMultiLine" android:minLines="3"
                android:layout_marginBottom="24dp"/>

            <LinearLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="end">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnCancelarEdicion"
                    android:layout_width="wrap_content" android:layout_height="40dp"
                    android:background="@drawable/boton_secundario"
                    android:text="Cancelar" android:textAllCaps="false"
                    android:textColor="@color/text_primary" android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:paddingStart="20dp" android:paddingEnd="20dp"
                    android:layout_marginEnd="10dp"/>

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnGuardar"
                    android:layout_width="wrap_content" android:layout_height="40dp"
                    android:background="@drawable/boton_principal_v2"
                    android:text="Guardar" android:textAllCaps="false"
                    android:textColor="@android:color/white" android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:paddingStart="20dp" android:paddingEnd="20dp"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
