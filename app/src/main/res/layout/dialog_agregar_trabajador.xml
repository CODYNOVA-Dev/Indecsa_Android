<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/dialog_bg"
    android:padding="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Título -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Agregar Trabajador"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp"/>

        <!-- Card principal -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Nombre -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nombre Completo *"
                    android:textColor="@color/label_color"
                    android:textSize="12sp"/>
                <EditText
                    android:id="@+id/editNombre"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/spinner_bg"
                    android:padding="10dp"
                    android:textSize="15sp"
                    android:textColor="@color/white"
                    android:hint="Nombre del trabajador"
                    android:textColorHint="@color/text_hint"
                    android:inputType="textPersonName"
                    android:layout_marginBottom="12dp"/>

                <!-- Especialidad -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Especialidad"
                    android:textColor="@color/label_color"
                    android:textSize="12sp"/>
                <EditText
                    android:id="@+id/editEspecialidad"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/spinner_bg"
                    android:padding="10dp"
                    android:textSize="15sp"
                    android:textColor="@color/white"
                    android:hint="Albañil, Electricista, etc."
                    android:textColorHint="@color/text_hint"
                    android:inputType="text"
                    android:layout_marginBottom="12dp"/>

                <!-- Correo -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Correo Electrónico"
                    android:textColor="@color/label_color"
                    android:textSize="12sp"/>
                <EditText
                    android:id="@+id/editCorreo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/spinner_bg"
                    android:padding="10dp"
                    android:textSize="15sp"
                    android:textColor="@color/white"
                    android:hint="correo@ejemplo.com"
                    android:textColorHint="@color/text_hint"
                    android:inputType="textEmailAddress"
                    android:layout_marginBottom="12dp"/>

                <!-- Teléfono -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Teléfono"
                    android:textColor="@color/label_color"
                    android:textSize="12sp"/>
                <EditText
                    android:id="@+id/editTelefono"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/spinner_bg"
                    android:padding="10dp"
                    android:textSize="15sp"
                    android:textColor="@color/white"
                    android:hint="5512345678"
                    android:textColorHint="@color/text_hint"
                    android:inputType="phone"
                    android:layout_marginBottom="12dp"/>

                <!-- NSS -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NSS (Número de Seguro Social)"
                    android:textColor="@color/label_color"
                    android:textSize="12sp"/>
                <EditText
                    android:id="@+id/editNss"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/spinner_bg"
                    android:padding="10dp"
                    android:textSize="15sp"
                    android:textColor="@color/white"
                    android:hint="12345678901"
                    android:textColorHint="@color/text_hint"
                    android:inputType="number"
                    android:layout_marginBottom="12dp"/>

                <!-- Ubicación -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ubicación"
                    android:textColor="@color/label_color"
                    android:textSize="12sp"/>
                <EditText
                    android:id="@+id/editUbicacion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/spinner_bg"
                    android:padding="10dp"
                    android:textSize="15sp"
                    android:textColor="@color/white"
                    android:hint="CDMX, Hidalgo, Puebla"
                    android:textColorHint="@color/text_hint"
                    android:inputType="text"
                    android:layout_marginBottom="12dp"/>

                <!-- Experiencia -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Experiencia"
                    android:textColor="@color/label_color"
                    android:textSize="12sp"/>
                <EditText
                    android:id="@+id/editExperiencia"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/spinner_bg"
                    android:padding="10dp"
                    android:textSize="15sp"
                    android:textColor="@color/white"
                    android:hint="Años de experiencia, proyectos previos..."
                    android:textColorHint="@color/text_hint"
                    android:inputType="textMultiLine"
                    android:minLines="2"
                    android:layout_marginBottom="12dp"/>

                <!-- Descripción -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Descripción"
                    android:textColor="@color/label_color"
                    android:textSize="12sp"/>
                <EditText
                    android:id="@+id/editDescripcion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/spinner_bg"
                    android:padding="10dp"
                    android:textSize="15sp"
                    android:textColor="@color/white"
                    android:hint="Descripción adicional del trabajador"
                    android:textColorHint="@color/text_hint"
                    android:inputType="textMultiLine"
                    android:minLines="3"
                    android:layout_marginBottom="20dp"/>

                <!-- Botones -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="end">

                    <Button
                        android:id="@+id/btnCancelar"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:background="@drawable/btn_coral"
                        android:text="Cancelar"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="14dp"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:layout_marginEnd="10dp"/>

                    <Button
                        android:id="@+id/btnGuardar"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:background="@drawable/btn_teal"
                        android:text="Guardar"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>