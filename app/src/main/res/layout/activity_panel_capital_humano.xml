<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_mas_claro">

    <LinearLayout
        android:id="@+id/header_CapitalHumano"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/fondo_encabezado"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingBottom="20dp">

        <ImageView
            android:layout_width="202dp"
            android:layout_height="116dp"
            android:src="@drawable/logo" />
    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/header_CapitalHumano"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="20dp"
        app:cardElevation="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="575dp"
            android:orientation="vertical"
            android:background="@color/spinner_border">

            <FrameLayout
                android:id="@+id/containerCapitalHumano"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <com.google.android.material.bottomnavigation.BottomNavigationView
                android:id="@+id/bottomNavCapitalHumano"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/tarjeta"
                android:elevation="4dp"
                app:itemIconTint="@color/nav_rail_item_color"
                app:itemTextColor="@color/nav_rail_item_color"
                app:labelVisibilityMode="labeled"
                app:menu="@menu/menu_caphum_bottom" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</RelativeLayout>