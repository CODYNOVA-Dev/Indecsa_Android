<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/dialog_bg"
    android:padding="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Título -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Agregar Proyecto"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp"/>

        <!-- Card principal -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Nombre del proyecto -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nombre del Proyecto *"
                    android:textColor="@color/label_color"
                    android:textSize="12sp"/>
                <EditText
                    android:id="@+id/editNombre"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/spinner_bg"
                    android:padding="10dp"
                    android:textSize="15sp"
                    android:textColor="@color/white"
                    android:hint="Nombre del proyecto"
                    android:textColorHint="@color/text_hint"
                    android:inputType="text"
                    android:layout_marginBottom="12dp"/>

                <!-- Tipo de proyecto -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tipo de Proyecto"
                    android:textColor="@color/label_color"
                    android:textSize="12sp"/>
                <EditText
                    android:id="@+id/editTipo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/spinner_bg"
                    android:padding="10dp"
                    android:textSize="15sp"
                    android:textColor="@color/white"
                    android:hint="Construcción, Remodelación, etc."
                    android:textColorHint="@color/text_hint"
                    android:inputType="text"
                    android:layout_marginBottom="12dp"/>

                <!-- Lugar -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Calle o Avenida"
                    android:textColor="@color/label_color"
                    android:textSize="12sp"/>
                <EditText
                    android:id="@+id/editLugar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/spinner_bg"
                    android:padding="10dp"
                    android:textSize="15sp"
                    android:textColor="@color/white"
                    android:hint="Dirección del proyecto"
                    android:textColorHint="@color/text_hint"
                    android:inputType="text"
                    android:layout_marginBottom="12dp"/>

                <!-- Municipio -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Municipio"
                    android:textColor="@color/label_color"
                    android:textSize="12sp"/>
                <EditText
                    android:id="@+id/editMunicipio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/spinner_bg"
                    android:padding="10dp"
                    android:textSize="15sp"
                    android:textColor="@color/white"
                    android:hint="Municipio"
                    android:textColorHint="@color/text_hint"
                    android:inputType="text"
                    android:layout_marginBottom="12dp"/>

                <!-- Fecha de inicio -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fecha de Inicio (yyyy-MM-dd)"
                    android:textColor="@color/label_color"
                    android:textSize="12sp"/>
                <EditText
                    android:id="@+id/editFechaIni"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/spinner_bg"
                    android:padding="10dp"
                    android:textSize="15sp"
                    android:textColor="@color/white"
                    android:hint="2024-01-15"
                    android:textColorHint="@color/text_hint"
                    android:inputType="date"
                    android:layout_marginBottom="12dp"/>

                <!-- Fecha de fin -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fecha de Fin (yyyy-MM-dd)"
                    android:textColor="@color/label_color"
                    android:textSize="12sp"/>
                <EditText
                    android:id="@+id/editFechaFin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/spinner_bg"
                    android:padding="10dp"
                    android:textSize="15sp"
                    android:textColor="@color/white"
                    android:hint="2024-12-31"
                    android:textColorHint="@color/text_hint"
                    android:inputType="date"
                    android:layout_marginBottom="20dp"/>

                <!-- Botones -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="end">

                    <Button
                        android:id="@+id/btnCancelar"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:background="@drawable/btn_coral"
                        android:text="Cancelar"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:layout_marginEnd="10dp"/>

                    <Button
                        android:id="@+id/btnGuardar"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:background="@drawable/btn_teal"
                        android:text="Guardar"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>