<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_mas_claro"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Formulario de captura -->
    <androidx.cardview.widget.CardView
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardBackgroundColor="#1A2B4C"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Registrar Horas Trabajadas"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Proyecto -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Proyecto"
                android:textColor="#A0AEC0"
                android:textSize="12sp" />

            <Spinner
                android:id="@+id/spinnerProyecto"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/button_dark_bg"
                android:paddingHorizontal="12dp"
                android:popupBackground="#1A2B4C" />

            <!-- Trabajador (asignación) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Trabajador"
                android:textColor="#A0AEC0"
                android:textSize="12sp" />

            <Spinner
                android:id="@+id/spinnerTrabajador"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/button_dark_bg"
                android:paddingHorizontal="12dp"
                android:popupBackground="#1A2B4C" />

            <!-- Cuadrilla (opcional) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cuadrilla (opcional)"
                android:textColor="#A0AEC0"
                android:textSize="12sp" />

            <Spinner
                android:id="@+id/spinnerCuadrilla"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/button_dark_bg"
                android:paddingHorizontal="12dp"
                android:popupBackground="#1A2B4C" />

            <!-- Fecha -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fecha de registro"
                android:textColor="#A0AEC0"
                android:textSize="12sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnFecha"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/button_dark_bg"
                android:gravity="center_vertical|start"
                android:paddingStart="12dp"
                android:text="Seleccionar fecha"
                android:textAllCaps="false"
                android:textColor="#A0AEC0"
                android:textSize="14sp" />

            <!-- Horas trabajadas -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Horas trabajadas"
                android:textColor="#A0AEC0"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/editHoras"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/button_dark_bg"
                android:hint="Ej: 8.0"
                android:inputType="numberDecimal"
                android:paddingHorizontal="12dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#5A6A7A"
                android:textSize="14sp" />

            <!-- Tipo período -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tipo de período"
                android:textColor="#A0AEC0"
                android:textSize="12sp" />

            <Spinner
                android:id="@+id/spinnerTipoPeriodo"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/button_dark_bg"
                android:paddingHorizontal="12dp"
                android:popupBackground="#1A2B4C" />

            <!-- Observaciones -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Observaciones (opcional)"
                android:textColor="#A0AEC0"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/editObservaciones"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/button_dark_bg"
                android:hint="Notas adicionales..."
                android:inputType="textMultiLine"
                android:lines="2"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#5A6A7A"
                android:textSize="14sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnRegistrar"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/button_azul_bg"
                android:text="Registrar horas"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Lista de registros -->
    <TextView
        android:id="@+id/textEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="24dp"
        android:text="Selecciona un proyecto para ver los registros"
        android:textColor="#5A6A7A"
        android:textSize="14sp"
        android:visibility="visible" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerRegistros"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone" />

</LinearLayout>
