<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/dialog_bg"
    android:padding="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ══════════════ PANEL DETALLE ══════════════ -->
        <LinearLayout
            android:id="@+id/panelDetalle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Detalle de proyecto"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="20dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="8dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Nombre del proyecto -->
                    <TextView
                        android:id="@+id/dialogTvNombre"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Nombre del Proyecto"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <!-- Badge estatus -->
                    <TextView
                        android:id="@+id/dialogTvEstatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/item_disp_verde"
                        android:text="● En curso"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider_color"
                        android:layout_marginBottom="14dp"/>

                    <!-- Tipo -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Tipo de proyecto" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <TextView android:id="@+id/dialogTvTipo"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="@color/white"
                        android:textSize="15sp" android:layout_marginBottom="12dp"/>

                    <!-- Estado + Municipio en fila -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Estado" android:textColor="@color/label_color" android:textSize="12sp"/>
                            <TextView android:id="@+id/dialogTvEstadoGeo"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="—" android:textColor="@color/white" android:textSize="15sp"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Municipio" android:textColor="@color/label_color" android:textSize="12sp"/>
                            <TextView android:id="@+id/dialogTvMunicipio"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="—" android:textColor="@color/white" android:textSize="15sp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Calle -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Calle o Avenida" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <TextView android:id="@+id/dialogTvLugar"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="—" android:textColor="@color/white"
                        android:textSize="15sp" android:layout_marginBottom="12dp"/>

                    <!-- Fechas en fila -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Fecha de inicio" android:textColor="@color/label_color" android:textSize="12sp"/>
                            <TextView android:id="@+id/dialogTvFechaIni"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="—" android:textColor="@color/white" android:textSize="15sp"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Fecha de fin" android:textColor="@color/label_color" android:textSize="12sp"/>
                            <TextView android:id="@+id/dialogTvFechaFin"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="—" android:textColor="@color/white" android:textSize="15sp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Calificación -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Calificación" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <RatingBar
                        android:id="@+id/dialogRatingBar"
                        style="?android:attr/ratingBarStyleSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:numStars="5"
                        android:stepSize="0.5"
                        android:isIndicator="true"
                        android:progressTint="#D4AF37"
                        android:secondaryProgressTint="#D4AF37"
                        android:layout_marginBottom="20dp"/>

                    <!-- Botones -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="end">

                        <Button
                            android:id="@+id/btnEliminar"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:background="@drawable/btn_coral"
                            android:text="Eliminar"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:layout_marginEnd="10dp"/>

                        <Button
                            android:id="@+id/btnEditar"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:background="@drawable/btn_teal"
                            android:text="Editar"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- ══════════════ PANEL EDITAR ══════════════ -->
        <LinearLayout
            android:id="@+id/panelEditar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Editar proyecto"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="20dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="8dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Nombre del proyecto" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <EditText android:id="@+id/editNombre"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="@drawable/spinner_bg" android:padding="10dp"
                        android:textSize="15sp" android:textColor="@color/white"
                        android:inputType="text" android:layout_marginBottom="12dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Tipo de proyecto" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <EditText android:id="@+id/editTipo"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="@drawable/spinner_bg" android:padding="10dp"
                        android:textSize="15sp" android:textColor="@color/white"
                        android:inputType="text" android:layout_marginBottom="12dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Municipio" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <EditText android:id="@+id/editMunicipio"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="@drawable/spinner_bg" android:padding="10dp"
                        android:textSize="15sp" android:textColor="@color/white"
                        android:inputType="text" android:layout_marginBottom="12dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Calle o Avenida" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <EditText android:id="@+id/editLugar"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="@drawable/spinner_bg" android:padding="10dp"
                        android:textSize="15sp" android:textColor="@color/white"
                        android:inputType="text" android:layout_marginBottom="12dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Fecha de inicio (yyyy-MM-dd)" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <EditText android:id="@+id/editFechaIni"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="@drawable/spinner_bg" android:padding="10dp"
                        android:textSize="15sp" android:textColor="@color/white"
                        android:hint="2024-01-15"
                        android:inputType="date" android:layout_marginBottom="12dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Fecha de fin (yyyy-MM-dd)" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <EditText android:id="@+id/editFechaFin"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="@drawable/spinner_bg" android:padding="10dp"
                        android:textSize="15sp" android:textColor="@color/white"
                        android:hint="2024-12-31"
                        android:inputType="date" android:layout_marginBottom="20dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="end">

                        <Button
                            android:id="@+id/btnCancelarEdicion"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:background="@drawable/btn_coral"
                            android:text="Cancelar"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:layout_marginEnd="10dp"/>

                        <Button
                            android:id="@+id/btnGuardar"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:background="@drawable/btn_teal"
                            android:text="Guardar"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

    </LinearLayout>
</ScrollView>