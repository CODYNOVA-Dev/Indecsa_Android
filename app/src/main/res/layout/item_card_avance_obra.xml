<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="#0F1E38"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeColor="#2D3748"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/textNombrePartida"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textActividad"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#A0AEC0"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/textCuadrilla"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#5A6A7A"
                    android:textSize="11sp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center|end"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/textCantidad"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#D4AF37"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textUnidad"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#A0AEC0"
                    android:textSize="11sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Barra de progreso (ejecutado vs programado) -->
        <LinearLayout
            android:id="@+id/layoutProgreso"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:visibility="gone">

            <ProgressBar
                android:id="@+id/progressAvance"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="0dp"
                android:layout_height="8dp"
                android:layout_gravity="center_vertical"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:max="100"
                android:progressTint="#D4AF37" />

            <TextView
                android:id="@+id/textPorcentaje"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#D4AF37"
                android:textSize="11sp" />

        </LinearLayout>

        <TextView
            android:id="@+id/textFecha"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#5A6A7A"
            android:textSize="11sp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
