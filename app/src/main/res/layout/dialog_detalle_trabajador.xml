<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/dialog_bg"
    android:padding="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ══════════════ PANEL DETALLE ══════════════ -->
        <LinearLayout
            android:id="@+id/panelDetalle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Detalle de trabajador"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="20dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="8dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Cabecera avatar + nombre + estado -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:id="@+id/dialogTvAvatar"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:background="@drawable/pill_blue"
                            android:gravity="center"
                            android:text="A"
                            android:textColor="@color/white"
                            android:textSize="22sp"
                            android:textStyle="bold"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="14dp">

                            <TextView
                                android:id="@+id/dialogTvNombre"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Nombre Trabajador"
                                android:textColor="@color/white"
                                android:textSize="17sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:id="@+id/dialogTvEstado"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="5dp"
                                android:background="@drawable/item_disp_verde"
                                android:text="● Activo"
                                android:textColor="@color/white"
                                android:textSize="11sp"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"
                                android:paddingTop="3dp"
                                android:paddingBottom="3dp"
                                android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider_color"
                        android:layout_marginBottom="14dp"/>

                    <!-- Especialidad -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Especialidad" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <TextView android:id="@+id/dialogTvEspecialidad"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="@color/white"
                        android:textSize="15sp" android:layout_marginBottom="12dp"/>

                    <!-- Correo -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Correo" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <TextView android:id="@+id/dialogTvCorreo"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="@color/white"
                        android:textSize="15sp" android:layout_marginBottom="12dp"/>

                    <!-- Teléfono -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Teléfono" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <TextView android:id="@+id/dialogTvTelefono"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="@color/white"
                        android:textSize="15sp" android:layout_marginBottom="12dp"/>

                    <!-- Experiencia -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Experiencia" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <TextView android:id="@+id/dialogTvExperiencia"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="—" android:textColor="@color/white"
                        android:textSize="15sp" android:layout_marginBottom="12dp"/>

                    <!-- Calificación -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Calificación" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <RatingBar
                        android:id="@+id/dialogRatingBar"
                        style="?android:attr/ratingBarStyleSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:numStars="5"
                        android:stepSize="0.5"
                        android:isIndicator="true"
                        android:progressTint="#D4AF37"
                        android:secondaryProgressTint="#D4AF37"
                        android:layout_marginBottom="12dp"/>

                    <!-- Descripción -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Descripción" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <TextView android:id="@+id/dialogTvDescripcion"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="—" android:textColor="@color/white"
                        android:textSize="15sp" android:layout_marginBottom="20dp"/>

                    <!-- ──── Rendimiento ──── -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider_color"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Rendimiento (últimos 30 días)"
                            android:textColor="@color/label_color"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <ProgressBar
                            android:id="@+id/progressRendimiento"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:visibility="gone" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvRendimientoVacio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Cargando..."
                        android:textColor="#5A6A7A"
                        android:textSize="12sp"
                        android:layout_marginBottom="8dp"
                        android:visibility="visible" />

                    <LinearLayout
                        android:id="@+id/containerRendimiento"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="12dp" />

                    <!-- Botones -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="end">

                        <Button
                            android:id="@+id/btnEstado"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:background="@drawable/button_dark_bg"
                            android:text="Estado"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:layout_marginEnd="10dp"/>

                        <Button
                            android:id="@+id/btnEliminar"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:background="@drawable/btn_coral"
                            android:text="Eliminar"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:layout_marginEnd="10dp"/>

                        <Button
                            android:id="@+id/btnEditar"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:background="@drawable/btn_teal"
                            android:text="Editar"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- ══════════════ PANEL EDITAR ══════════════ -->
        <LinearLayout
            android:id="@+id/panelEditar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Editar trabajador"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="20dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="8dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- ── Datos personales ── -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Datos personales" android:textColor="@color/primary_orange"
                        android:textSize="13sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Nombre" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <EditText android:id="@+id/editNombre"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="@drawable/spinner_bg" android:padding="10dp"
                        android:textSize="15sp" android:textColor="@color/white"
                        android:inputType="textPersonName" android:layout_marginBottom="12dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="CURP" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <EditText android:id="@+id/editCurp"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="@drawable/spinner_bg" android:padding="10dp"
                        android:textSize="15sp" android:textColor="@color/white"
                        android:inputType="textCapCharacters" android:maxLength="18"
                        android:layout_marginBottom="12dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="RFC" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <EditText android:id="@+id/editRfc"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="@drawable/spinner_bg" android:padding="10dp"
                        android:textSize="15sp" android:textColor="@color/white"
                        android:inputType="textCapCharacters" android:maxLength="13"
                        android:layout_marginBottom="12dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="NSS" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <EditText android:id="@+id/editNss"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="@drawable/spinner_bg" android:padding="10dp"
                        android:textSize="15sp" android:textColor="@color/white"
                        android:inputType="number" android:layout_marginBottom="12dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Nacionalidad" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <EditText android:id="@+id/editNacionalidad"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="@drawable/spinner_bg" android:padding="10dp"
                        android:textSize="15sp" android:textColor="@color/white"
                        android:inputType="text" android:layout_marginBottom="12dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Sexo" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <Spinner android:id="@+id/spinnerSexo"
                        android:layout_width="match_parent" android:layout_height="48dp"
                        android:background="@drawable/spinner_bg" android:layout_marginBottom="12dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Estado civil" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <EditText android:id="@+id/editEstadoCivil"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="@drawable/spinner_bg" android:padding="10dp"
                        android:textSize="15sp" android:textColor="@color/white"
                        android:inputType="text" android:layout_marginBottom="12dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Teléfono" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <EditText android:id="@+id/editTelefono"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="@drawable/spinner_bg" android:padding="10dp"
                        android:textSize="15sp" android:textColor="@color/white"
                        android:inputType="phone" android:layout_marginBottom="12dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Correo" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <EditText android:id="@+id/editCorreo"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="@drawable/spinner_bg" android:padding="10dp"
                        android:textSize="15sp" android:textColor="@color/white"
                        android:inputType="textEmailAddress" android:layout_marginBottom="12dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Foto de perfil (URL)" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <EditText android:id="@+id/editFoto"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="@drawable/spinner_bg" android:padding="10dp"
                        android:textSize="15sp" android:textColor="@color/white"
                        android:inputType="textUri" android:maxLength="255" android:layout_marginBottom="16dp"/>

                    <!-- ── Datos laborales ── -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Datos laborales" android:textColor="@color/primary_orange"
                        android:textSize="13sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Puesto" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <EditText android:id="@+id/editPuesto"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="@drawable/spinner_bg" android:padding="10dp"
                        android:textSize="15sp" android:textColor="@color/white"
                        android:inputType="text" android:layout_marginBottom="12dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Especialidad" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <EditText android:id="@+id/editEspecialidad"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="@drawable/spinner_bg" android:padding="10dp"
                        android:textSize="15sp" android:textColor="@color/white"
                        android:inputType="text" android:layout_marginBottom="12dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Descripción del puesto" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <EditText android:id="@+id/editDescripcion"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="@drawable/spinner_bg" android:padding="10dp"
                        android:textSize="15sp" android:textColor="@color/white"
                        android:inputType="textMultiLine" android:minLines="2"
                        android:layout_marginBottom="12dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Escolaridad" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <EditText android:id="@+id/editEscolaridad"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="@drawable/spinner_bg" android:padding="10dp"
                        android:textSize="15sp" android:textColor="@color/white"
                        android:inputType="text" android:layout_marginBottom="12dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Experiencia" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <EditText android:id="@+id/editExperiencia"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="@drawable/spinner_bg" android:padding="10dp"
                        android:textSize="15sp" android:textColor="@color/white"
                        android:inputType="textMultiLine" android:minLines="2"
                        android:layout_marginBottom="12dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Contratación" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <EditText android:id="@+id/editContratacion"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="@drawable/spinner_bg" android:padding="10dp"
                        android:textSize="15sp" android:textColor="@color/white"
                        android:inputType="text" android:layout_marginBottom="12dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Jornada" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <EditText android:id="@+id/editJornada"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="@drawable/spinner_bg" android:padding="10dp"
                        android:textSize="15sp" android:textColor="@color/white"
                        android:inputType="text" android:layout_marginBottom="12dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Fecha de ingreso" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <androidx.appcompat.widget.AppCompatButton android:id="@+id/btnFechaIngreso"
                        android:layout_width="match_parent" android:layout_height="48dp"
                        android:background="@drawable/spinner_bg" android:gravity="center_vertical|start"
                        android:paddingStart="10dp" android:text="Seleccionar fecha"
                        android:textAllCaps="false" android:textColor="@color/white"
                        android:textSize="15sp" android:layout_marginBottom="12dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Calificación" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <RatingBar android:id="@+id/editRating"
                        style="?android:attr/ratingBarStyleSmall"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:numStars="5" android:stepSize="1"
                        android:layout_marginTop="4dp" android:layout_marginBottom="16dp"/>

                    <!-- ── Domicilio ── -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Domicilio" android:textColor="@color/primary_orange"
                        android:textSize="13sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Calle" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <EditText android:id="@+id/editCalle"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="@drawable/spinner_bg" android:padding="10dp"
                        android:textSize="15sp" android:textColor="@color/white"
                        android:inputType="text" android:layout_marginBottom="12dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Número exterior" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <EditText android:id="@+id/editNumExt"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="@drawable/spinner_bg" android:padding="10dp"
                        android:textSize="15sp" android:textColor="@color/white"
                        android:inputType="text" android:layout_marginBottom="12dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Número interior" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <EditText android:id="@+id/editNumInt"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="@drawable/spinner_bg" android:padding="10dp"
                        android:textSize="15sp" android:textColor="@color/white"
                        android:inputType="text" android:layout_marginBottom="12dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Colonia" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <EditText android:id="@+id/editColonia"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="@drawable/spinner_bg" android:padding="10dp"
                        android:textSize="15sp" android:textColor="@color/white"
                        android:inputType="text" android:layout_marginBottom="12dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Código postal" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <EditText android:id="@+id/editCodPost"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="@drawable/spinner_bg" android:padding="10dp"
                        android:textSize="15sp" android:textColor="@color/white"
                        android:inputType="number" android:maxLength="5" android:layout_marginBottom="12dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Municipio / Alcaldía" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <EditText android:id="@+id/editMunAlc"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="@drawable/spinner_bg" android:padding="10dp"
                        android:textSize="15sp" android:textColor="@color/white"
                        android:inputType="text" android:layout_marginBottom="12dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Estado" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <Spinner android:id="@+id/spinnerEstadoDom"
                        android:layout_width="match_parent" android:layout_height="48dp"
                        android:background="@drawable/spinner_bg" android:layout_marginBottom="16dp"/>

                    <!-- ── Datos adicionales ── -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Datos adicionales" android:textColor="@color/primary_orange"
                        android:textSize="13sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Idiomas" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <EditText android:id="@+id/editIdiomas"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="@drawable/spinner_bg" android:padding="10dp"
                        android:textSize="15sp" android:textColor="@color/white"
                        android:inputType="text" android:layout_marginBottom="12dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Lengua indígena" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <EditText android:id="@+id/editLenguaIndigena"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="@drawable/spinner_bg" android:padding="10dp"
                        android:textSize="15sp" android:textColor="@color/white"
                        android:inputType="text" android:layout_marginBottom="12dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Antecedentes penales" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <EditText android:id="@+id/editAntPenal"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="@drawable/spinner_bg" android:padding="10dp"
                        android:textSize="15sp" android:textColor="@color/white"
                        android:inputType="text" android:layout_marginBottom="12dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Deudor alimentario" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <EditText android:id="@+id/editDeudorAlim"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="@drawable/spinner_bg" android:padding="10dp"
                        android:textSize="15sp" android:textColor="@color/white"
                        android:inputType="text" android:layout_marginBottom="12dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Folio licencia de conducir" android:textColor="@color/label_color" android:textSize="12sp"/>
                    <EditText android:id="@+id/editFolioLic"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="@drawable/spinner_bg" android:padding="10dp"
                        android:textSize="15sp" android:textColor="@color/white"
                        android:inputType="text" android:layout_marginBottom="20dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="end">

                        <Button
                            android:id="@+id/btnCancelarEdicion"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:background="@drawable/btn_coral"
                            android:text="Cancelar"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:layout_marginEnd="10dp"/>

                        <Button
                            android:id="@+id/btnGuardar"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:background="@drawable/btn_teal"
                            android:text="Guardar"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

    </LinearLayout>
</ScrollView>