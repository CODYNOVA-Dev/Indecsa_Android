<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#1A2B4C"
    app:cardCornerRadius="24dp"
    app:cardElevation="8dp"
    app:strokeColor="#40FFFFFF"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_horizontal">

        <LinearLayout
            android:layout_width="180dp"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="12dp">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/circle_border"
                android:padding="16dp"
                android:src="@drawable/caphum"
                app:tint="#D4AF37" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Capital Humano"
                android:textAlignment="center"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:padding="5dp"
                android:gravity="center"
                android:text="Gestiona usuarios de capital humano: altas, consultas y permisos de acceso."
                android:textColor="#A0AEC0"
                android:textSize="14sp" />

        </LinearLayout>



        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:layout_marginVertical="20dp"
            android:background="#2D3748" />

        <LinearLayout
            android:layout_width="196dp"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="12dp">

            <androidx.appcompat.widget.AppCompatButton
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/button_dark_bg"
                android:drawableStart="@drawable/dot_green"
                android:drawablePadding="12dp"
                android:paddingStart="20dp"
                android:text="Registrar usuario CH"
                android:textAllCaps="false"
                android:textColor="#A0AEC0"
                android:gravity="center_vertical" />

            <androidx.appcompat.widget.AppCompatButton
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/button_dark_bg"
                android:drawableStart="@drawable/dot_blue"
                android:drawablePadding="12dp"
                android:paddingStart="20dp"
                android:text="Ver lista de usuarios"
                android:textAllCaps="false"
                android:textColor="#A0AEC0"
                android:gravity="center_vertical" />

            <androidx.appcompat.widget.AppCompatButton
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:background="@drawable/button_dark_bg"
                android:drawableStart="@drawable/dot_orange"
                android:drawablePadding="12dp"
                android:paddingStart="20dp"
                android:text="Editar permisos y datos del usuario"
                android:textAllCaps="false"
                android:textColor="#A0AEC0"
                android:gravity="center_vertical" />
        </LinearLayout>



    </LinearLayout>
</com.google.android.material.card.MaterialCardView>