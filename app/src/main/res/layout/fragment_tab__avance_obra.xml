<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_mas_claro">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Formulario de captura -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#1A2B4C"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="Registrar Avance de Partida"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- Proyecto -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Proyecto"
                    android:textColor="#A0AEC0"
                    android:textSize="12sp" />

                <Spinner
                    android:id="@+id/spinnerProyecto"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/button_dark_bg"
                    android:paddingHorizontal="12dp"
                    android:popupBackground="#1A2B4C" />

                <!-- Cuadrilla (opcional) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cuadrilla (opcional)"
                    android:textColor="#A0AEC0"
                    android:textSize="12sp" />

                <Spinner
                    android:id="@+id/spinnerCuadrilla"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/button_dark_bg"
                    android:paddingHorizontal="12dp"
                    android:popupBackground="#1A2B4C" />

                <!-- Estándar (opcional) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Estándar de rendimiento (opcional)"
                    android:textColor="#A0AEC0"
                    android:textSize="12sp" />

                <Spinner
                    android:id="@+id/spinnerEstandar"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/button_dark_bg"
                    android:paddingHorizontal="12dp"
                    android:popupBackground="#1A2B4C" />

                <!-- Nombre partida -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nombre de la partida *"
                    android:textColor="#A0AEC0"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/editNombrePartida"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/button_dark_bg"
                    android:hint="Ej: Colado de losa nivel 2"
                    android:inputType="text"
                    android:paddingHorizontal="12dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#5A6A7A"
                    android:textSize="14sp" />

                <!-- Fecha -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fecha de registro"
                    android:textColor="#A0AEC0"
                    android:textSize="12sp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnFecha"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/button_dark_bg"
                    android:gravity="center_vertical|start"
                    android:paddingStart="12dp"
                    android:text="Seleccionar fecha"
                    android:textAllCaps="false"
                    android:textColor="#A0AEC0"
                    android:textSize="14sp" />

                <!-- Cantidad ejecutada -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cantidad ejecutada *"
                    android:textColor="#A0AEC0"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/editCantidadEjecutada"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/button_dark_bg"
                    android:hint="Ej: 12.5"
                    android:inputType="numberDecimal"
                    android:paddingHorizontal="12dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#5A6A7A"
                    android:textSize="14sp" />

                <!-- Unidad de medida -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Unidad de medida *"
                    android:textColor="#A0AEC0"
                    android:textSize="12sp" />

                <Spinner
                    android:id="@+id/spinnerUnidad"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/button_dark_bg"
                    android:paddingHorizontal="12dp"
                    android:popupBackground="#1A2B4C" />

                <!-- Cantidad programada (opcional) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cantidad programada (opcional)"
                    android:textColor="#A0AEC0"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/editCantidadProgramada"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/button_dark_bg"
                    android:hint="Ej: 15.0"
                    android:inputType="numberDecimal"
                    android:paddingHorizontal="12dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#5A6A7A"
                    android:textSize="14sp" />

                <!-- Observaciones -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Observaciones (opcional)"
                    android:textColor="#A0AEC0"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/editObservaciones"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/button_dark_bg"
                    android:hint="Notas adicionales..."
                    android:inputType="textMultiLine"
                    android:lines="2"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#5A6A7A"
                    android:textSize="14sp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnRegistrar"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/button_azul_bg"
                    android:text="Registrar avance"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Lista de avances recientes -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Avances registrados"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="16dp"
            android:text="Selecciona un proyecto para ver los avances"
            android:textColor="#5A6A7A"
            android:textSize="14sp"
            android:visibility="visible" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerAvances"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
