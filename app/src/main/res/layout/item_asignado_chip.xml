<?xml version="1.0" encoding="utf-8"?>
<!--
    item_asignado_chip.xml
    Ruta: res/layout/item_asignado_chip.xml

    Fila que muestra un item asignado (contratista o trabajador)
    con su nombre y un botón "✕" para quitarlo.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="6dp"
    android:paddingHorizontal="4dp">

    <!-- Bullet / avatar círculo -->
    <TextView
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:text="●"
        android:textSize="10sp"
        android:textColor="?attr/colorPrimary"
        android:gravity="center"
        android:layout_marginEnd="10dp"/>

    <!-- Nombre del asignado -->
    <TextView
        android:id="@+id/tvNombreAsignado"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textSize="14sp"
        android:textColor="?attr/colorOnSurface"
        android:maxLines="1"
        android:ellipsize="end"/>

    <!-- Botón quitar -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnQuitarAsignado"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:text="✕"
        android:textSize="12sp"
        android:padding="0dp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:textColor="?attr/colorError"
        style="@style/Widget.MaterialComponents.Button.TextButton"/>

</LinearLayout>