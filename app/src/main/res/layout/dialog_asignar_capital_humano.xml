<?xml version="1.0" encoding="utf-8"?>
<!--
    dialog_asignar_capital_humano.xml
    Ruta: res/layout/dialog_asignar_capital_humano.xml

    Dialog para asignar contratista y trabajadores a un proyecto.
    Reglas: máx 1 contratista, máx 8 trabajadores, sin duplicados.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/dialog_bg"
    android:padding="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Título -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Asignar Capital Humano"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <!-- Subtítulo proyecto -->
        <TextView
            android:id="@+id/tvTituloProyecto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Proyecto"
            android:textColor="@color/label_color"
            android:textSize="13sp"
            android:layout_marginBottom="20dp" />

        <!-- Card principal -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- ══════════════ SECCIÓN CONTRATISTA ══════════════ -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Contratista"
                        android:textColor="@color/header_orange"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <!-- Contador: X/1 -->
                    <TextView
                        android:id="@+id/tvContadorContratistas"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0/1"
                        android:textColor="@color/label_color"
                        android:textSize="13sp"
                        android:paddingEnd="8dp" />

                    <Button
                        android:id="@+id/btnAgregarContratista"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="+ Agregar"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textAllCaps="false"
                        android:background="@drawable/btn_teal"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp" />
                </LinearLayout>

                <!-- Lista de contratistas asignados -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvContratistasAsignados"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:layout_marginBottom="12dp" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider_color"
                    android:layout_marginBottom="16dp" />

                <!-- ══════════════ SECCIÓN TRABAJADORES ══════════════ -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Trabajadores"
                        android:textColor="@color/header_orange"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <!-- Contador: X/8 -->
                    <TextView
                        android:id="@+id/tvContadorTrabajadores"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0/8"
                        android:textColor="@color/label_color"
                        android:textSize="13sp"
                        android:paddingEnd="8dp" />

                    <Button
                        android:id="@+id/btnAgregarTrabajador"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="+ Agregar"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textAllCaps="false"
                        android:background="@drawable/btn_teal"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp" />
                </LinearLayout>

                <!-- Lista de trabajadores asignados -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvTrabajadoresAsignados"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:layout_marginBottom="16dp" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider_color"
                    android:layout_marginBottom="16dp" />

                <!-- ══════════════ BOTONES FINALES ══════════════ -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="end">

                    <Button
                        android:id="@+id/btnCerrarAsignacion"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="Cancelar"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        android:textAllCaps="false"
                        android:background="@drawable/btn_coral"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:layout_marginEnd="8dp" />

                    <Button
                        android:id="@+id/btnGuardarAsignacion"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="Guardar asignación"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        android:textAllCaps="false"
                        android:background="@drawable/btn_teal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp" />

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>